generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum PmsProvider {
  MOCK
  REZDY
  INSEANQ
  FAREHARBOR
  BOKUN
  NATIVE
}

enum ConversationControlMode {
  AI
  HUMAN
  PAUSED
}

enum ManualInquiryStatus {
  OPEN
  OPERATOR_NOTIFIED
  CLOSED
}

enum BluePassInquiryStatus {
  DRAFT
  READY_TO_DISPATCH
  OPERATOR_PENDING
  OPERATOR_ACCEPTED
  COUNTER_OFFERED
  DECLINED
  CLOSED
}

enum BluePassLedgerKind {
  CREATOR_COMMISSION_ESTIMATE
  BLUEPASS_PLATFORM_COMMISSION
  CONSERVATION_ALLOCATION
  OPERATOR_PAYOUT_PLACEHOLDER
}

enum BluePassLedgerStatus {
  PENDING
  FINALIZED
  VOIDED
}

enum BluePassOperatorDispatchStatus {
  QUEUED
  SENT
  FAILED
}

model Tenant {
  id              String              @id @default(cuid())
  slug            String              @unique
  name            String
  status          TenantStatus        @default(ACTIVE)
  widgetPublicKey String              @unique
  allowedOrigins  String[]
  defaultLocale   String              @default("en")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  branding        TenantBranding?
  config          TenantConfig?
  integrations    TenantIntegration[]
  conversations   Conversation[]
  manualInquiries ManualInquiry[]
}

model TenantBranding {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  logoUrl        String?
  primaryColor   String
  widgetTitle    String
  welcomeMessage String
  brandVoice     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantConfig {
  id                 String      @id @default(cuid())
  tenantId           String      @unique
  supportedChannels  String[]
  enabledFeatures    String[]
  requiredSlots      Json
  bookingMode        String
  bookingWriteEnabled Boolean    @default(false)
  pmsProvider        PmsProvider @default(MOCK)
  publicProductCatalog Json       @default("[]")
  escalationRules    String[]
  responseGuardrails String[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  tenant             Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantIntegration {
  id                   String      @id @default(cuid())
  tenantId             String
  provider             PmsProvider
  encryptedCredentials String
  status               String
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
}

model Conversation {
  id          String                  @id @default(cuid())
  tenantId    String
  controlMode ConversationControlMode @default(AI)
  channel     String
  travellerId String?
  leadId      String?
  // E.164 digits (no "+") — set for WhatsApp-channel conversations so the
  // webhook can find the thread for an inbound sender.
  whatsappPhone String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  tenant          Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages        Message[]
  bookingState    ConversationBookingState?
  manualInquiries ManualInquiry[]

  @@unique([tenantId, whatsappPhone])
}

model Message {
  id             String   @id @default(cuid())
  tenantId       String
  conversationId String
  role           String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, conversationId, createdAt])
}

model ConversationBookingState {
  id                String   @id @default(cuid())
  tenantId          String
  conversationId    String   @unique
  productExternalId String?
  productTitle      String?
  dateText          String?
  guests            Int?
  travellerName     String?
  travellerEmail    String?
  travellerPhone    String?
  bookingStatus     String   @default("DRAFT")
  confirmationSummary String?
  externalBookingId String?
  externalProvider  String?
  bookingError      String?
  timeOptions       Json?
  ticketOptions     Json?
  ticketQuantities  Json?
  extraOptions      Json?
  extraQuantities   Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, conversationId])
}

model ManualInquiry {
  id                String              @id @default(cuid())
  tenantId          String
  conversationId    String
  status            ManualInquiryStatus @default(OPEN)
  productExternalId String?
  productTitle      String?
  dateText          String?
  guests            Int?
  travellerName     String?
  travellerEmail    String?
  travellerPhone    String?
  travellerMessage  String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, conversationId, createdAt])
}

model BluePassInquiry {
  id                String                @id @default(cuid())
  tenantId          String
  conversationId    String
  status            BluePassInquiryStatus @default(DRAFT)
  sourceChannel     String                @default("WEB_WIDGET")
  travellerName     String?
  travellerEmail    String?
  travellerPhone    String?
  destination       String?
  tripType          String?
  dateWindow        String?
  guests            Int?
  budget            String?
  interests         Json?
  selectedYachtSlug String?
  selectedYachtName String?
  operatorId        String?
  operatorName      String?
  operatorPhone     String?
  notes             String?
  travellerMessage  String
  referralPartnerId String?
  referralLinkId    String?
  referralCode      String?
  referralRole      String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  events     BluePassInquiryEvent[]
  ledger     BluePassLedgerEntry[]
  dispatches BluePassOperatorDispatch[]

  @@index([tenantId, conversationId, status, createdAt])
  @@index([tenantId, status, createdAt])
}

model BluePassInquiryEvent {
  id                String   @id @default(cuid())
  tenantId          String
  conversationId    String
  bluePassInquiryId String
  type              String
  fromStatus        String?
  toStatus          String?
  metadata          Json?
  createdAt         DateTime @default(now())

  inquiry BluePassInquiry @relation(fields: [bluePassInquiryId], references: [id], onDelete: Cascade)

  @@index([tenantId, conversationId, createdAt])
  @@index([bluePassInquiryId, createdAt])
}

model BluePassLedgerEntry {
  id                String               @id @default(cuid())
  tenantId          String
  conversationId    String
  bluePassInquiryId String
  kind              BluePassLedgerKind
  amountCents       Int
  currency          String               @default("USD")
  status            BluePassLedgerStatus @default(PENDING)
  referralPartnerId String?
  referralLinkId    String?
  referralCode      String?
  referralRole      String?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  inquiry BluePassInquiry @relation(fields: [bluePassInquiryId], references: [id], onDelete: Cascade)

  @@index([tenantId, conversationId, status, createdAt])
  @@index([bluePassInquiryId, status])
}

model BluePassOperatorDispatch {
  id                String                         @id @default(cuid())
  tenantId          String
  conversationId    String
  bluePassInquiryId String
  status            BluePassOperatorDispatchStatus @default(QUEUED)
  operatorId        String?
  operatorName      String?
  operatorPhone     String
  outboundText      String
  providerMessageId String?
  failureReason     String?
  metadata          Json?
  sentAt            DateTime?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt

  inquiry BluePassInquiry @relation(fields: [bluePassInquiryId], references: [id], onDelete: Cascade)

  @@index([tenantId, conversationId, status, createdAt])
  @@index([bluePassInquiryId, createdAt])
}
