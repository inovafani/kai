DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@REGION.pooler.supabase.com:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-me"
SUPABASE_SERVICE_ROLE_KEY="replace-me"
PMS_CREDENTIAL_ENCRYPTION_KEY="replace-with-32-byte-base64-key"
# Shared with BluePass app KAI_CORE_ADMIN_TOKEN for the read-only admin bridge.
KAI_ADMIN_TOKEN="replace-with-strong-admin-bridge-token"
BLUEPASS_APP_URL="https://bluepass.co"
# Set true only once BLUEPASS_APP_URL points at a deployment with /api/kai/catalog-snapshot live -
# lets kai's WhatsApp path pull real operator-listing/yacht data instead of the static preview
# catalog. Off by default so test/dev environments never attempt this network call unexpectedly.
BLUEPASS_WHATSAPP_CATALOG_FETCH_ENABLED="false"
# Optional; falls back to KAI_ADMIN_TOKEN. Must match BluePass app KAI_CORE_ADMIN_TOKEN or BLUEPASS_SERVICE_TOKEN.
BLUEPASS_APP_SERVICE_TOKEN=""
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
ENABLE_OPENAI_LLM="false"
ENABLE_LLM="false"
OPENAI_TIMEOUT_MS="3000"
LLM_PROVIDER="groq"
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"
GROQ_TIMEOUT_MS="3000"
LLM_MAX_OUTPUT_TOKENS="260"

REZDY_BASE_URL="https://api.rezdy.com"
REZDY_API_KEY=""
REZDY_PRODUCT_LIST_PATH="/v1/products"
REZDY_AVAILABILITY_PATH="/v1/availability"
REZDY_BOOKING_PATH="/v1/bookings"
REZDY_TIMEOUT_MS="5000"
REZDY_STRIPE_PUBLISHABLE_KEY=""
REZDY_CHECKOUT_BASE_URL=""
REZDY_SERVICE_ID_MAP=""
# Keep false; confirmed bookings should go through RezdyPay tokenized payment.
KAI_ALLOW_UNPAID_EXTERNAL_BOOKINGS="false"
INSEANQ_BASE_URL=""
INSEANQ_API_KEY=""
INSEANQ_PRODUCT_LIST_PATH=""
INSEANQ_AVAILABILITY_PATH=""
INSEANQ_TIMEOUT_MS="5000"

# Optional local fallback when a selected operator has no phone.
BLUEPASS_TEST_OPERATOR_PHONE=""
# Set true only for local demos when every operator inquiry should go to BLUEPASS_TEST_OPERATOR_PHONE.
BLUEPASS_FORCE_TEST_OPERATOR_PHONE="false"
# Production operator routing. Keys can be yacht slug, operator id, yacht name, or operator name.
# Example: {"calico-jack":"628xxxxxxxxxx","operator_alila_purnama":"628yyyyyyyyyy"}
BLUEPASS_OPERATOR_PHONE_OVERRIDES=""
WHATSAPP_OPERATOR_INQUIRY_SEND_MODE="queue"
WHATSAPP_TRAVELLER_NOTIFY_SEND_MODE="template"
WHATSAPP_TRAVELLER_UPDATE_TEMPLATE="bluepass_inquiry_update"
WHATSAPP_TRAVELLER_UPDATE_TEMPLATE_LANGUAGE="en"
WHATSAPP_OPERATOR_COUNTER_REQUEST_SEND_MODE="text"
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
META_GRAPH_VERSION="v20.0"
WHATSAPP_PHONE_ID_KAI=""
WHATSAPP_PHONE_ID_OPS=""
WHATSAPP_ACCESS_TOKEN=""
# Comma-separated tenant slugs the shared WhatsApp number should also route to the generic
# tenant/PMS booking engine for, checked by product/business-name mention before falling
# through to the BluePass marketplace path. Empty/unset = no generic routing (today's behavior).
WHATSAPP_GENERIC_TENANT_SLUGS=""
